{
  "name": "@convertly-sh/sdk",
  "version": "0.3.0",
  "description": "Official JavaScript and TypeScript SDK for the Convertly media API.",
  "homepage": "https://convertly.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/convertly-sh/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/convertly-sh/sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "convertly",
    "media",
    "image",
    "video",
    "compression",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@convertly-sh/image": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
